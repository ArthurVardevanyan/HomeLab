{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Universal Homelab Release Updater (Ansible & Docker)",
      "managerFilePatterns": [
        "/^ansible/playbooks/.*\\.yaml$/",
        "/(^|/)Dockerfile$/",
        "/(^|/)Containerfile$/",
        "/(^|/)containerfile$/"
      ],
      "matchStrings": [
        "# renovate: custom-github-release depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\n\\s+url: .*?/releases/download/v?(?<currentValue>[^/]+)/",
        "# renovate: custom-github-release depName=(?<depName>[^\\s]+).*?\\n\\s+url: .*?_(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)_",
        "# renovate: custom-github-release depName=(?<depName>[^\\s]+).*?\\n\\s+url: .*?linux-(?:arm64-)?(?<currentValue>[\\w.-]+?)\\.tar\\.gz",
        "# renovate: custom-github-release depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\n\\s*OKD_VERSION=(?<currentValue>[^\\s\\\\]+)\\s*\\\\",
        "# renovate: datasource=(?<datasource>pypi) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\n\\s+-\\s+.*?==(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update vm-cluster.yaml clusterVersion",
      "managerFilePatterns": ["/vm-cluster\\.yaml$/"],
      "matchStrings": [
        "(?<comment>#\\s*renovate:\\s*datasource=(?<datasource>.*?) depName=(?<depName>.*?)(?: versioning=(?<versioning>.*?))?)\\s+clusterVersion:\\s+\"(?<currentValue>.*)-cluster\""
      ],
      "autoReplaceStringTemplate": "{{{comment}}}\n  clusterVersion: \"{{{newVersion}}}-cluster\""
    },
    {
      "customType": "regex",
      "description": "Update ArgoCD manifests with SHA256 digests",
      "managerFilePatterns": ["/argocd\\.yaml$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>.*?) depName=(?<depName>.*?)(?: versioning=(?<versioning>.*?))?\\s+(?:-\\s+)?\\w+:\\s+(?<currentDigest>sha256:[a-f0-9]+)\\s*#\\s*(?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "MCP server npm packages pinned via npx args (VS Code mcp.json, opencode.json, scafctl mcp configs)",
      "managerFilePatterns": [
        "/\\.vscode/mcp\\.json$/",
        "/(^|/)opencode\\.json$/",
        "/machineConfigs/.*/(mcp|opencode)\\.json$/"
      ],
      "matchStrings": [
        "\"(?<depName>[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)?)@(?<currentValue>\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/external-secrets/external-secrets"],
      "groupName": "External Secrets Operator"
    },
    {
      "matchDatasources": ["github-releases"],
      "matchManagers": ["custom.regex"],
      "groupName": "Homelab Binaries",
      "separateMajorMinor": false
    }
  ]
}
