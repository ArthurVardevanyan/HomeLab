{
  "repositories": [
    "ArthurVardevanyan/ArthurVardevanyan-com",
    "ArthurVardevanyan/bmc-shim",
    "ArthurVardevanyan/FinanceTracker",
    "ArthurVardevanyan/Homelab",
    "ArthurVardevanyan/k8s-federated-credential-api",
    "ArthurVardevanyan/kube-eagle",
    "ArthurVardevanyan/openshift-monitoring-cr-controller",
    "ArthurVardevanyan/Analytics-for-Spotify",
    "ArthurVardevanyan/wasm-wiretap"
  ],
  "gitAuthor": "homelab-okd[bot] <139566794+homelab-okd[bot]@users.noreply.github.com>",
  "automerge": false,
  "prHourlyLimit": 0,
  "postUpdateOptions": ["gomodTidy"],
  "ansible": {
    "enabled": false
  },
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch"],
      "matchFileNames": [".pre-commit-config.yaml"],
      "groupName": "Pre-commit Hooks"
    },
    {
      "matchDatasources": ["docker"],
      "groupName": "Container Updates"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "Go Modules",
      "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"]
    },
    {
      "matchManagers": ["gomod"],
      "matchDepTypes": ["indirect"],
      "matchUpdateTypes": ["minor", "patch"],
      "enabled": true
    },
    {
      "matchManagers": ["terraform"],
      "matchDepTypes": ["required_provider"],
      "groupName": "Terraform Providers"
    },
    {
      "matchManagers": [
        "pip_requirements",
        "pip-compile",
        "pep621",
        "poetry",
        "pipenv"
      ],
      "groupName": "Python Dependencies"
    },

    {
      "matchManagers": ["cargo"],
      "groupName": "Rust Crates"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.pre-commit-config.yaml$/"],
      "matchStrings": ["rev: v0\\.(?<currentValue>[^\\s]+)"],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "shellcheck-py/shellcheck-py",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v0\\.(?<version>.*)$",
      "autoReplaceStringTemplate": "rev: v0.{{{newVersion}}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.yaml$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>.*?) depName=(?<depName>.*?)(?: versioning=(?<versioning>.*?))?\\s+(?:-\\s+)?\\w+:\\s+(?:[^@\\s]*:)?(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>\\S+))?"
      ]
    }
  ]
}
